import java.util.Scanner;
public class Main {
    public static void showReverse(int n, Scanner sc) {
        if (n == 0) return;
        int x = sc.nextInt();
        showReverse(n - 1, sc);
        System.out.print(x + " ");
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        showReverse(n, sc);
    }
}
